NODE_ENV=development
PORT=3333
API_HOST=0.0.0.0
LOG_LEVEL=info
SWAGGER_ENABLED=true
RATE_LIMIT_MAX=100

# Banco de dados — secretos, apenas backend/Prisma
DATABASE_URL=postgresql://<USUARIO>:<SENHA>@<HOST>:<PORTA>/<BANCO>?sslmode=require
DIRECT_URL=postgresql://<USUARIO>:<SENHA>@<HOST_DIRETO>:<PORTA>/<BANCO>?sslmode=require
DATABASE_URL_TEST=postgresql://gym_platform:gym_platform_test_password@localhost:55432/gym_platform_test?schema=public
ALLOW_TEST_DATABASE_RESET=false

# Redis
REDIS_URL=redis://localhost:6379

# Aplicação (Backend)
CORS_ORIGINS=http://localhost:3000
AUTH_ADAPTER=supabase-jwt
ORGANIZATION_SELF_SERVICE_ENABLED=false

# Supabase servidor — nunca expor no frontend
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_JWKS_URL=https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json

# Admin Web
ADMIN_API_BASE_URL=http://localhost:3333
ADMIN_AUTH_ADAPTER=supabase-jwt
ADMIN_ORGANIZATION_ID=
ADMIN_UNIT_ID=
ADMIN_DEV_USER_ID=

# Supabase público — pode ser usado apenas pelo admin-web
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<CHAVE_PUBLICA>

# Release e smoke (somente pipeline/operacao; o token deve ser curto e secreto)
RELEASE_ENV=staging
RELEASE_API_URL=https://api.staging.example.com
RELEASE_ADMIN_WEB_URL=https://admin.staging.example.com
RELEASE_SMOKE_ACCESS_TOKEN=
RELEASE_SMOKE_ORGANIZATION_ID=
RELEASE_SMOKE_FORBIDDEN_ORGANIZATION_ID=

# Provisionamento fechado (somente execucao operacional; nunca usar na aplicacao)
BETA_PROVISION_ENV=staging
BETA_PROVISION_DATABASE_URL=
BETA_PROVISION_EXPECTED_DATABASE=gym_staging
BETA_PROVISION_ACTOR_USER_ID=
BETA_PROVISION_CREATE_USER=false
BETA_PROVISION_ACTOR_NAME=
BETA_PROVISION_ACTOR_EMAIL=
BETA_PROVISION_ORGANIZATION_TYPE=GYM
BETA_PROVISION_ORGANIZATION_LEGAL_NAME=
BETA_PROVISION_ORGANIZATION_TRADE_NAME=
BETA_PROVISION_ORGANIZATION_SLUG=
BETA_PROVISION_DEFAULT_UNIT_NAME=Unidade Principal
BETA_PROVISION_CONFIRM=
